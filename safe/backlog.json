    {"id": "E11", "theme": "ST2", "pi": "PI-6", "status": "done", "name": "Multi-market rigor", "hypothesis": "A price-based point-in-time backtest and FX-normalised comparison make all 19 markets rigorously comparable, not just the US."},
    {"id": "E12", "theme": "ST4", "pi": "PI-6", "status": "done", "name": "Data observability", "hypothesis": "Freshness/completeness/outlier checks on the data (not just the code) catch silent data rot."},
    {"id": "E13", "theme": "ST2", "pi": "PI-7", "status": "done", "name": "Quality factor (QMJ)", "hypothesis": "The AFP/QMJ quality factor (Jacob-Pradeep-Varma, IIMA 2022) — profitability/growth/safety/payout via standardised ranks — earns a valuation premium and adds a sticky, fundamentals-based signal to the ensemble across markets."},
    {"id": "E14", "theme": "ST2", "pi": "PI-7", "status": "done", "name": "Literature scouting", "hypothesis": "An automated scout over open scholarly APIs, seeded from the implemented papers, keeps the platform current and surfaces research gaps (frontier themes not yet implemented) as a feed into the backlog."},
    {"id": "E15", "theme": "ST2", "pi": "PI-7", "status": "done", "name": "PEAD factor (scout-driven)", "hypothesis": "Post-earnings-announcement drift — the scout's top-ranked research gap — implemented as a price-based, lookahead-free event study across markets; closes the scout->implement->covered loop and adds a drift signal to the ensemble."},
    {"id": "E16", "theme": "ST2", "pi": "PI-7", "status": "done", "name": "Liquidity factor (scout-driven)", "hypothesis": "The Amihud (2002) illiquidity measure and liquidity premium — the scout's second gap — implemented from OHLC across 19 markets; yields a validated tradeability/capacity score for the ensemble and position sizing."}
  ],
